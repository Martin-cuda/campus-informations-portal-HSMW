# ----------------------------------------------------------------------
# Campus-Informationsportal -- Beispiel-Konfiguration
# Kopiere diese Datei zu  backend/.env  und ergaenze die Werte.
# WICHTIG: .env NIE ins Git committen (steht in .gitignore).
# ----------------------------------------------------------------------

# -- JEROME: Neon-Postgres + JWT --
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/db?sslmode=require
SECRET_KEY=CHANGE_ME_TO_SOMETHING_LONG_AND_RANDOM

# -- ARI (Ticket 3): SMTP fuer Mensa-Notification-Mails --
# Aktuell genutzt: dedizierter Gmail-Account campusportal.hsmw@gmail.com
# Wenn ihr selber testen wollt: entweder
#   (a) leer lassen -> Dry-Run-Modus, Mails landen nur im Server-Log, oder
#   (b) eigenen SMTP-Account eintragen (Gmail / web.de / GMX / etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=campusportal.hsmw@gmail.com
SMTP_PASS=<APP_PASSWORT_BEI_ARI_ERFRAGEN>
SMTP_FROM=Campus Portal HSMW <campusportal.hsmw@gmail.com>
SMTP_USE_TLS=1
SMTP_DEBUG=0
PUBLIC_BASE_URL=http://localhost:8000
