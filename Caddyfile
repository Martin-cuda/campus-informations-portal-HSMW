http://localhost:8080 {
    encode gzip zstd

    # Gehashte Vite-Assets (Dateiname ändert sich bei jedem Build) dürfen aggressiv
    # und unveränderlich gecacht werden → schnelle Folge-Ladezeiten, kein Re-Download.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    root * ./frontend/dist

    handle /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    handle /auth/* {
        reverse_proxy 127.0.0.1:8000
    }

    handle /login {
        reverse_proxy 127.0.0.1:8000
    }

    handle /protected {
        reverse_proxy 127.0.0.1:8000
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
